{
  "name": "crystal-growth-simulator",
  "version": "0.1.0",
  "private": true,
  "description": "Live browser simulator for snowflake, dendrite, and coral-like crystal growth with WebGPU visuals and sonified physics.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/prepare-build.mjs",
    "build": "vite build && node scripts/postbuild.mjs",
    "test": "vitest run --coverage",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "smoke": "bash scripts/smoke.sh",
    "lint": "eslint .",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "pages-preview": "bash scripts/pages-preview.sh",
    "hooks:pre-commit": "bash .githooks/pre-commit",
    "hooks:commit-msg": "bash .githooks/commit-msg .git/COMMIT_EDITMSG",
    "hooks:pre-push": "bash .githooks/pre-push",
    "version:stamp": "node scripts/stamp-version.mjs"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "three": "^0.171.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.2",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@webgpu/types": "^0.1.69",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "http-server": "^14.1.1",
    "jsdom": "^25.0.1",
    "pngjs": "^7.0.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^8.0.11",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22"
  }
}
